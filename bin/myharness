#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

if [[ -x "${ROOT}/dist/myharness-local" ]]; then
  exec "${ROOT}/dist/myharness-local" "$@"
fi

if command -v go >/dev/null 2>&1; then
  exec go run "${ROOT}/cmd/myharness" "$@"
fi

echo "myharness: install Go or build dist/myharness-local with ./build.sh --cli" >&2
exit 127
